{
  "manifestVersion": 1,
  "publisher": "chloeteo",
  "name": "KubeDock Security Scan",
  "description": "An extension to be used in Azure Pipelines to scan Kubernetes manifests and Dockerfiles with Checkov, and publish results to the pipeline summary.",
  "public": true,
  "categories": ["Azure Repos"],
  "demands": ["api-version/5.1"],
  "scopes": [
    "vso.code",
    "vso.build",
    "vso.graph",
    "vso.work"
  ],
  "targets": [{
    "id": "Microsoft.VisualStudio.Services"
  }],
  "repository": {
    "type": "git",
    "url": "https://github.com/chloe-teo/kubediffscan"
  },
  "icons": {
    "default": "marketplace/logo.png",
    "branding": "marketplace/logo.png"
  },
  "content": {
    "details": {
      "path": "marketplace/overview.md"
    },
    "license": {
      "path": "marketplace/LICENSE.md"
    }
  },
  "tags": ["checkov-scanner", "k8s-scanner", "dockerfile-scanner", "helm-scanner", "container-security", "kubernetes-security", "devsecops"],
  "screenshots": [],
  "files": [{
      "path": "build",
      "addressable": true
    },
    {
      "path": "marketplace",
      "addressable": true
    }
  ]
}