{
  "manifestVersion": 1,
  "id": "kubedock-security-scan-dev",
  "publisher": "chloe-teo10",
  "version": "0.0.1",
  "name": "KubeDock Security Scan",
  "description": "A task to be used in Azure Pipelines to scan Kubernetes manifests and Dockerfiles with Checkov, and publish results to the pipeline summary.",
  "public": false,
  "categories": ["Azure Pipelines"],
  "scopes": [
    "vso.build"
  ],
  "targets": [{
    "id": "Microsoft.VisualStudio.Services"
  }],
  "repository": {
    "type": "git",
    "url": "https://github.com/chloe-teo/kubedock-security-scan"
  },
  "icons": {
    "default": "marketplace/logo.png",
    "branding": "marketplace/logo.png"
  },
  "content": {
    "details": {
      "path": "marketplace/overview.md"
    },
    "license": {
      "path": "marketplace/LICENSE.md"
    }
  },
  "tags": ["checkov-scanner", "k8s-scanner", "dockerfile-scanner", "helm-scanner", "container-security", "kubernetes-security", "devsecops"],
  "screenshots": [],
  "files": [
    { "path": "src/dist", "addressable": true },
    { "path": "src/images", "addressable": true },
    { "path": "src/enhancer", "addressable": true },
    { "path": "src/lib", "addressable": true },
    { "path": "src/task.json", "addressable": true },
    { "path": "src/tab.html", "addressable": true },
    { "path": "src/styles.css", "addressable": true },
    { "path": "marketplace", "addressable": true }
  ],
  "contributions": [
    {
      "id": "kubedock-security-scan-dev",
      "type": "ms.vss-distributed-task.task",
      "targets": ["ms.vss-distributed-task.tasks"],
      "properties": {
        "name": "src"
      }
    },
    {
      "id": "kubedock-scan-tab-dev",
      "type": "ms.vss-build-web.build-results-tab",
      "description": "KubeDock Security Scan results tab",
      "targets": ["ms.vss-build-web.build-results-view"],
      "properties": {
        "name": "KubeDock Scan",
        "uri": "src/tab.html",
        "supportsTasks": ["12c53210-6fb5-4726-8055-c3b4435e0a44"]
      }
    }
  ]
}